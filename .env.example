# ── DeepSeek API (обов'язково) ────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=8000

# ── Telegram — публічний канал (обов'язково) ──────────────
TG_BOT_TOKEN=
TG_CHAT_ID=
TG_THREAD_ID=119

# ── Telegram — адмін (необов'язково) ─────────────────────
ADMIN_CHAT_ID=
ADMIN_THREAD_ID=

# ── Mastodon (обов'язково) ────────────────────────────────
MASTO_INSTANCE=https://social.vir.group/
MASTO_TOKEN=
MASTO_ENABLED=true

# ── Bluesky (необов'язково) ───────────────────────────────
BS_HANDLE=
BS_APP_PASSWORD=
BS_ENABLED=true

# ── WordPress (обов'язково) ───────────────────────────────
WP_URL=https://newsgroup.site/wp-json/wp/v2/posts
WP_USER=
WP_APP_PASSWORD=
WP_CATEGORY_ID=505
WP_ENABLED=true

# ── Pexels (необов'язково) ────────────────────────────────
PEXELS_API_KEY=

# ── YaCy пошук ───────────────────────────────────────────
YACY_URL=https://search.newsgroup.site/yacysearch.json
YACY_MAX=6

# ── Ліміти постів ─────────────────────────────────────────
MIN_IMPORTANCE=1
MAX_ALERTS_RUN=3
MAX_RED_DAY=150
MAX_YELLOW_DAY=80
MAX_GREEN_DAY=15

# ── Шляхи в контейнері (не змінювати якщо не знаєш навіщо)
DB_PATH=/data/dedup.db
LOG_PATH=/data/agent.log
LOCK_FILE=/tmp/osint_agent.lock
